{
  "all": true,
  "src": ["src"],
  "include": ["**/*.{ts,tsx}"],
  "exclude": ["dist", "node_modules", "**/*.test.ts", "**/test-*.ts", "cli.tsx"],
  "reporter": ["text", "html", "lcov"],
  "reports-dir": "./coverage",
  "check-coverage": true,
  "lines": 80,
  "branches": 80,
  "functions": 80,
  "statements": 80,
  "skip-full": true,
  "extension": [".ts", ".tsx"]
}
