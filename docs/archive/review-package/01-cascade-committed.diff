+          'text-anchor': 'middle', 'letter-spacing': '0.1em'
+        }, ['SIGNAL-TO-NOISE']));
+
+        // Scale labels
+        const labels = ['Poor', 'Fair', 'Good', 'Excellent'];
+        labels.forEach((l, i) => {
+          const a = startAngle + (i / (labels.length - 1)) * totalAngle;
+          const p = polarToRect(a, r + 18);
+          svg.appendChild(el('text', {
+            x: p.x, y: p.y,
+            fill: 'rgba(224,224,240,0.4)', 'font-size': '9',
+            'text-anchor': 'middle'
+          }, [l]));
+        });
+      })();
+
+      // ── Heatmap ───────────────────────────────────────────────────────────────
+      (function buildHeatmap() {
+        const svg = document.getElementById('heatmap');
+        const W = 420, H = 300;
+        const pad = { top: 30, right: 20, bottom: 40, left: 50 };
+        const cw = W - pad.left - pad.right;
+        const ch = H - pad.top - pad.bottom;
+
+        const items = [
+          { name: 'Tool Config',       x: 0.2, y: 0.3 },
+          { name: 'Workspace Setup',   x: 0.1, y: 0.2 },
+          { name: 'Ecosystem Risk',    x: 0.3, y: 0.8 },
+          { name: 'Implementation',    x: 0.2, y: 0.4 },
+          { name: 'Maintenance',       x: 0.4, y: 0.6 },
+        ];
+
+        const xScale = v => pad.left + v * cw;
+        const yScale = v => pad.top + (1 - v) * ch;
+
+        // Heat background — interpolate colour grid
+        const cols = 20, rows = 20;
+        const cellW = cw / cols, cellH = ch / rows;
+        for (let xi = 0; xi < cols; xi++) {
+          for (let yi = 0; yi < rows; yi++) {
+            const fx = xi / (cols - 1), fy = 1 - yi / (rows - 1);
+            // Hotter = higher probability AND impact
+            const heat = fx * fy;
+            const r = Math.round(255 * heat);
+            const g = Math.round(255 * (1 - heat) * 0.4);
+            const b = Math.round(80 * (1 - heat));
+            svg.appendChild(el('rect', {
+              x: pad.left + xi * cellW,
+              y: pad.top + yi * cellH,
+              width: cellW + 0.5, height: cellH + 0.5,
+              fill: `rgba(${r},${g},${b},${0.25 + heat * 0.35})`
+            }));
+          }
