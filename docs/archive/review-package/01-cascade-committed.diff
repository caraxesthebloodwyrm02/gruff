@@ -0,0 +1,23 @@
+# Makefile for DIO
+
+.PHONY: help install run test lint format clean
+
+help:
+	@echo "DIO Development Commands"
+	@grep -E '^[a-zA-Z_-]+:.*?## .*382358' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = ":.*?## "}; {printf "  %-15s %s\n", $$1, $$2}'
+
+install:
+	uv sync
+
+test:
+	uv run pytest tests/ -q --tb=short
+
+lint:
+	uv run ruff check .
+
+format:
+	uv run ruff format .
+
+clean:
+	find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
+	rm -rf .pytest_cache .ruff_cache
