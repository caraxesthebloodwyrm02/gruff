+        const yL2 = el('text', { x: 12, y: pad.top + 4, fill: 'rgba(224,224,240,0.45)', 'font-size': '10', 'text-anchor': 'end', transform: `rotate(-90, 12, ${pad.top + 4})` }, ['High Impact']);
+        svg.appendChild(yL1);
