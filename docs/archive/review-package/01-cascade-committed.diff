+
+      // ── Gauge ─────────────────────────────────────────────────────────────────
+      (function buildGauge() {
+        const svg = document.getElementById('gauge');
+        const W = 420, H = 220;
+        const cx = W / 2, cy = H - 40;
+        const r = 110;
+        const val = 85;
+
+        const startAngle = Math.PI;
+        const endAngle = 0;
+        const totalAngle = Math.PI;
+
+        function polarToRect(angle, radius) {
+          return { x: cx + radius * Math.cos(angle), y: cy + radius * Math.sin(angle) };
+        }
+
+        function arcPath(r, a1, a2) {
+          const s = polarToRect(a1, r);
+          const e = polarToRect(a2, r);
+          const large = Math.abs(a2 - a1) > Math.PI ? 1 : 0;
+          return `M ${s.x} ${s.y} A ${r} ${r} 0 ${large} 1 ${e.x} ${e.y}`;
+        }
+
+        // Background arc
+        svg.appendChild(el('path', {
+          d: arcPath(r, startAngle, endAngle),
+          stroke: 'rgba(255,255,255,0.08)', 'stroke-width': '18',
+          fill: 'none', 'stroke-linecap': 'round'
+        }));
+
+        // Color segments: 0-25 red, 25-50 amber, 50-75 yellow, 75-100 green
+        const segments = [
+          { from: 0, to: 25, color: '#ff3366' },
+          { from: 25, to: 50, color: '#ff7733' },
+          { from: 50, to: 75, color: '#ffcc44' },
+          { from: 75, to: 100, color: '#00ff88' },
