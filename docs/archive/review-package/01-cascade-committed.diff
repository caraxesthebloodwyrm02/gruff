@@ -0,0 +1,210 @@
+import { mkdirSync, mkdtempSync, rmSync } from "fs";
+import os from "os";
+import path from "path";
+import { afterAll, beforeAll, beforeEach, describe, expect, it } from "vitest";
+
+import {
+  getAnticipationEngine,
+  generateAnticipationSignals,
+  getAnticipationStatus,
+} from "../src/anticipation.js";
+import { appendLogEntries, clearAllLogs } from "../src/storage.js";
+import type { LogEntry } from "../src/types.js";
+
+describe("anticipation engine", () => {
+  const tempRoot = mkdtempSync(path.join(os.tmpdir(), "ori-anticipation-"));
+
+  beforeAll(async () => {
+    const oriDataDir = path.join(tempRoot, ".ori");
+    const echoesDataDir = path.join(tempRoot, ".echoes");
+    process.env.ORI_DATA_DIR = oriDataDir;
+    process.env.ECHOES_DATA_DIR = echoesDataDir;
+    process.env.ECHOES_AUDIT_PATH = path.join(echoesDataDir, "audit.ndjson");
+    process.env.CASCADE_WORKSPACE_ROOT = "/home/irfankabir/workspace/CascadeProjects";
+
+    mkdirSync(oriDataDir, { recursive: true });
+    mkdirSync(echoesDataDir, { recursive: true });
+  });
+
+  afterAll(() => {
+    delete process.env.ORI_DATA_DIR;
+    delete process.env.ECHOES_DATA_DIR;
+    delete process.env.ECHOES_AUDIT_PATH;
+    delete process.env.CASCADE_WORKSPACE_ROOT;
+    rmSync(tempRoot, { recursive: true, force: true });
+  });
+
+  beforeEach(async () => {
+    await clearAllLogs();
+  });
+
+  it("generates anticipation signals when risk threshold is met", async () => {
+    // Create test entries that should trigger anticipation
+    const testEntries: LogEntry[] = [
+      {
+        id: "test-1",
+        timestamp: new Date().toISOString(),
+        line: "TimeoutError: Test execution timed out",
+        source: "mcp-ori-server",
+        severity: "critical",
+        matchedPatterns: ["timeout"],
+      },
+      {
+        id: "test-2",
+        timestamp: new Date().toISOString(),
+        line: "Memory leak detected",
+        source: "mcp-ori-server",
+        severity: "warning",
+        matchedPatterns: ["memory_leak"],
+      },
+      {
+        id: "test-3",
+        timestamp: new Date().toISOString(),
+        line: "Another timeout occurred",
+        source: "mcp-ori-server",
+        severity: "critical",
+        matchedPatterns: ["timeout"],
+      },
+      {
+        id: "test-4",
+        timestamp: new Date().toISOString(),
+        line: "Network connection refused",
+        source: "mcp-ori-server",
+        severity: "warning",
+        matchedPatterns: ["network_error"],
+      },
+      {
+        id: "test-5",
+        timestamp: new Date().toISOString(),
+        line: "Third timeout detected",
+        source: "mcp-ori-server",
+        severity: "critical",
+        matchedPatterns: ["timeout"],
+      },
+    ];
+
+    await appendLogEntries(testEntries);
