+          svg.appendChild(el('line', { x1: pad.left, y1: y, x2: pad.left + cw, y2: y, stroke: 'rgba(255,255,255,0.06)', 'stroke-width': '1' }));
+        }
+
+        // Axes
+        svg.appendChild(el('line', { x1: pad.left, y1: pad.top + ch, x2: pad.left + cw, y2: pad.top + ch, stroke: 'rgba(255,255,255,0.2)', 'stroke-width': '1' }));
+        svg.appendChild(el('line', { x1: pad.left, y1: pad.top, x2: pad.left, y2: pad.top + ch, stroke: 'rgba(255,255,255,0.2)', 'stroke-width': '1' }));
+
+        // Axis labels
+        svg.appendChild(el('text', { x: pad.left, y: H - 4, fill: 'rgba(224,224,240,0.45)', 'font-size': '10' }, ['Low Prob.']));
+        svg.appendChild(el('text', { x: pad.left + cw, y: H - 4, fill: 'rgba(224,224,240,0.45)', 'font-size': '10', 'text-anchor': 'end' }, ['High Prob.']));
+        const yL1 = el('text', { x: 12, y: pad.top + ch, fill: 'rgba(224,224,240,0.45)', 'font-size': '10', 'text-anchor': 'end', transform: `rotate(-90, 12, ${pad.top + ch})` }, ['Low Impact']);
+        const yL2 = el('text', { x: 12, y: pad.top + 4, fill: 'rgba(224,224,240,0.45)', 'font-size': '10', 'text-anchor': 'end', transform: `rotate(-90, 12, ${pad.top + 4})` }, ['High Impact']);
+        svg.appendChild(yL1);
