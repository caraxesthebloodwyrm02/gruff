+        segments.forEach(s => {
+          const a1 = startAngle + (s.from / 100) * totalAngle;
+          const a2 = startAngle + (s.to / 100) * totalAngle;
+          svg.appendChild(el('path', {
+            d: arcPath(r, a1, a2),
+            stroke: s.color, 'stroke-width': '18',
+            fill: 'none', 'stroke-linecap': 'butt', opacity: '0.35'
+          }));
+        });
+
+        // Value arc
+        const valAngle = startAngle + (val / 100) * totalAngle;
+        svg.appendChild(el('path', {
+          d: arcPath(r, startAngle, valAngle),
+          stroke: '#00ff88', 'stroke-width': '18',
+          fill: 'none', 'stroke-linecap': 'round'
+        }));
+
+        // Needle
+        const needleAngle = startAngle + (val / 100) * totalAngle;
+        const needleTip = polarToRect(needleAngle, r - 10);
+        const needleBase1 = polarToRect(needleAngle + Math.PI / 2, 8);
+        const needleBase2 = polarToRect(needleAngle - Math.PI / 2, 8);
