+          const dotColor = heat > 0.2 ? '#ffcc44' : '#00ff88';
+          const px = xScale(d.x), py = yScale(d.y);
+          svg.appendChild(el('circle', { cx: px, cy: py, r: '10', fill: dotColor, opacity: '0.12' }));
