diff --git a/Components/shared-types/src/command-bus.ts b/Components/shared-types/src/command-bus.ts
new file mode 100644
index 0000000..cfe8110
--- /dev/null
+++ b/Components/shared-types/src/command-bus.ts
@@ -0,0 +1,125 @@
+import { appendFileSync, existsSync, mkdirSync, readFileSync, watch } from "fs";
+import type { FSWatcher } from "fs";
+import { homedir } from "os";
+import { dirname, resolve } from "path";
+import { z } from "zod";
+import { appendNdjsonLine, sanitizeForNdjson } from "./audit-client.js";
+import { generateId, isRunId } from "./id.js";
+
+const ECHOES_AUDIT_PATH =
+  process.env.ECHOES_AUDIT_PATH || resolve(homedir(), ".echoes", "audit.ndjson");
+
+export const NamespaceSchema = z.string().regex(/^[a-z][a-z0-9-]*$/);
+export type Namespace = z.infer<typeof NamespaceSchema>;
+
+export const CommandEnvelopeSchema = z.object({
+  id: z.string(),
+  runId: z.string(),
+  ns: NamespaceSchema,
+  source: z.string(),
+  command: z.string(),
+  payload: z.record(z.string(), z.unknown()),
+  timestamp: z.string().datetime(),
+});
+export type CommandEnvelope = z.infer<typeof CommandEnvelopeSchema>;
+
+export type CommandHandler = (envelope: CommandEnvelope) => void | Promise<void>;
+
+export interface Subscription {
+  unsubscribe(): void;
+}
+
+export async function dispatch(
+  envelope: Omit<CommandEnvelope, "id" | "timestamp"> & { id?: string },
+): Promise<boolean> {
+  if (!isRunId(envelope.runId)) {
+    throw new Error(`Invalid runId "${envelope.runId}" for command dispatch.`);
+  }
+  const record: CommandEnvelope = CommandEnvelopeSchema.parse({
+    ...envelope,
+    id: envelope.id ?? generateId("cmd"),
+    payload: sanitizeForNdjson(envelope.payload) as Record<string, unknown>,
+    timestamp: new Date().toISOString(),
+  });
+  return appendNdjsonLine(JSON.stringify(record));
+}
+
+export function subscribe(ns: Namespace, handler: CommandHandler): Subscription {
+  NamespaceSchema.parse(ns);
+
+  const tailOnly = process.env.ECHOES_COMMAND_BUS_TAIL_ONLY === "1";
+  let closed = false;
+  let offset = 0;
+  let watcher: FSWatcher | null = null;
+
+  const flush = () => {
+    if (closed) return;
+    if (!existsSync(ECHOES_AUDIT_PATH)) {
+      return;
+    }
+
+    const raw = readFileSync(ECHOES_AUDIT_PATH);
+    if (tailOnly && offset === 0) {
+      offset = raw.length;
+      return;
+    }
+    if (raw.length < offset) {
+      offset = 0;
+    }
+
+    const chunk = raw.subarray(offset).toString("utf8");
+    offset = raw.length;
+    if (!chunk) return;
+
+    for (const line of chunk.split("\n")) {
+      const trimmed = line.trim();
+      if (!trimmed) continue;
+
+      let parsed: unknown;
+      try {
+        parsed = JSON.parse(trimmed);
+      } catch {
+        continue;
+      }
+
+      const envelope = CommandEnvelopeSchema.safeParse(parsed);
+      if (!envelope.success) continue;
+      if (envelope.data.ns !== ns) continue;
+
+      try {
+        const out = handler(envelope.data);
+        if (out && typeof (out as Promise<unknown>).then === "function") {
+          (out as Promise<unknown>).catch((err) => {
+            process.stderr.write(`[command-bus] handler rejected: ${String(err)}\n`);
+          });
+        }
+      } catch (err) {
+        process.stderr.write(`[command-bus] handler failed: ${String(err)}\n`);
+      }
+    }
+  };
+
+  // Ensure file exists so fs.watch can attach reliably.
+  mkdirSync(dirname(ECHOES_AUDIT_PATH), { recursive: true });
+  appendFileSync(ECHOES_AUDIT_PATH, "", { flag: "a" });
+
+  flush();
+
+  try {
+    watcher = watch(ECHOES_AUDIT_PATH, () => {
+      flush();
+    });
+  } catch {
+    watcher = null;
+  }
+
+  const poller = setInterval(flush, 1000);
+
+  return {
+    unsubscribe() {
+      closed = true;
+      clearInterval(poller);
+      if (watcher) watcher.close();
+    },
+  };
+}
diff --git a/Components/shared-types/src/id.ts b/Components/shared-types/src/id.ts
index 0206f2f..1c0325a 100644
--- a/Components/shared-types/src/id.ts
+++ b/Components/shared-types/src/id.ts
@@ -1,4 +1,4 @@
-import { randomBytes } from "node:crypto";
+import { randomBytes, randomUUID } from "node:crypto";
 
 /**
  * Generate a cryptographically secure unique ID with a prefix.
@@ -7,3 +7,57 @@ import { randomBytes } from "node:crypto";
 export function generateId(prefix: string): string {
   return `${prefix}-${Date.now()}-${randomBytes(4).toString("hex")}`;
 }
+
+/**
+ * Structured run identifier: {service}.{kind}.{uuid}.
+ * Enables cross-service correlation without a central registry.
+ */
+export interface RunId {
+  service: string;
+  kind: string;
+  uuid: string;
+}
+
+const RUN_ID_SEGMENT = /^[a-z][a-z0-9-]*$/;
+
+function assertSegment(name: "service" | "kind", value: string): void {
+  if (!RUN_ID_SEGMENT.test(value)) {
+    throw new Error(
+      `Invalid ${name} "${value}": must match /^[a-z][a-z0-9-]*$/ (lowercase, alphanumeric, dashes; no dots).`,
+    );
+  }
+}
+
+/**
+ * Generate a structured run id of the form {service}.{kind}.{uuid}.
+ * `service` and `kind` must be lowercase-kebab (no dots).
+ */
+export function generateRunId(service: string, kind: string): string {
+  assertSegment("service", service);
+  assertSegment("kind", kind);
+  return `${service}.${kind}.${randomUUID()}`;
+}
+
+/**
+ * Parse a run id. Returns null if the shape does not match
+ * {service}.{kind}.{uuid} with valid service/kind segments.
+ */
+export function parseRunId(id: string): RunId | null {
+  const firstDot = id.indexOf(".");
+  if (firstDot <= 0) return null;
+  const secondDot = id.indexOf(".", firstDot + 1);
+  if (secondDot <= firstDot + 1) return null;
+  const service = id.slice(0, firstDot);
+  const kind = id.slice(firstDot + 1, secondDot);
+  const uuid = id.slice(secondDot + 1);
+  if (!uuid) return null;
+  if (!RUN_ID_SEGMENT.test(service) || !RUN_ID_SEGMENT.test(kind)) return null;
+  return { service, kind, uuid };
+}
+
+/**
+ * Type guard: does `id` conform to the run-id scheme?
+ */
+export function isRunId(id: string): boolean {
+  return parseRunId(id) !== null;
+}
