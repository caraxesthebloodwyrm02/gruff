+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="UTF-8" />
+    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
+    <title>Idea-Risk Map</title>
+    <style>
+      :root {
+        --bg: #06060e;
+        --surface: #0f0f1e;
+        --border: rgba(255, 255, 255, 0.08);
+        --text: #e0e0f0;
+        --muted: rgba(224, 224, 240, 0.45);
+        --accent: #00ccff;
+        --accent2: #ff3366;
+        --green: #00ff88;
+        --amber: #ffcc44;
+        --grid: rgba(255, 255, 255, 0.04);
+      }
+
+      * { margin: 0; padding: 0; box-sizing: border-box; }
+
+      body {
+        background: var(--bg);
+        color: var(--text);
+        font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
+        font-size: 12px;
+        min-height: 100vh;
+        padding: 32px;
+      }
+
+      h1 {
+        font-size: 18px;
+        font-weight: 500;
+        letter-spacing: 0.12em;
+        text-transform: uppercase;
+        color: var(--accent);
+        margin-bottom: 8px;
+      }
+
+      .subtitle {
+        color: var(--muted);
+        font-size: 11px;
+        letter-spacing: 0.06em;
+        margin-bottom: 32px;
+      }
+
+      .grid {
+        display: grid;
+        grid-template-columns: 1fr 1fr;
+        grid-template-rows: auto auto;
+        gap: 20px;
+        max-width: 1100px;
+      }
+
+      .panel {
+        background: var(--surface);
+        border: 1px solid var(--border);
+        border-radius: 6px;
+        padding: 20px;
+      }
+
+      .panel-title {
+        font-size: 10px;
+        letter-spacing: 0.14em;
+        text-transform: uppercase;
+        color: var(--muted);
+        margin-bottom: 16px;
+      }
+
+      svg {
+        display: block;
+        overflow: visible;
+      }
+
+      .metrics-row {
+        grid-column: 1 / -1;
+        display: grid;
+        grid-template-columns: repeat(5, 1fr);
+        gap: 12px;
+      }
+
+      .metric-card {
+        background: var(--surface);
+        border: 1px solid var(--border);
+        border-radius: 6px;
+        padding: 16px 12px;
+        text-align: center;
+      }
+
+      .metric-value {
+        font-size: 22px;
+        font-weight: 600;
+        margin-bottom: 4px;
+      }
+
+      .metric-label {
+        font-size: 10px;
+        letter-spacing: 0.08em;
+        color: var(--muted);
+        text-transform: uppercase;
+        line-height: 1.4;
+      }
+
+      .legend {
+        margin-top: 12px;
+        display: flex;
+        gap: 16px;
+        flex-wrap: wrap;
+      }
+
+      .legend-item {
+        display: flex;
+        align-items: center;
+        gap: 6px;
+        font-size: 10px;
+        color: var(--muted);
+      }
+
+      .legend-dot {
+        width: 8px;
+        height: 8px;
+        border-radius: 50%;
+        flex-shrink: 0;
+      }
+
+      .legend-line {
+        width: 20px;
+        height: 2px;
+        flex-shrink: 0;
+      }
+    </style>
+  </head>
+  <body>
+    <h1>Idea-Risk Map</h1>
+    <p class="subtitle">Session analysis · April 15, 2026 · 5 concepts evaluated</p>
+
+    <div class="grid">
+
+      <!-- SCATTER: Complexity vs Value -->
+      <div class="panel">
+        <div class="panel-title">Complexity vs Expected Value</div>
+        <svg id="scatter" width="100%" viewBox="0 0 420 300"></svg>
+        <div class="legend">
+          <div class="legend-item"><div class="legend-dot" style="background:#00ccff"></div>Ideas</div>
+          <div class="legend-item"><div class="legend-line" style="background:#ff3366"></div>Risk threshold (y=5)</div>
+        </div>
+      </div>
+
+      <!-- QUADRANT CHART -->
+      <div class="panel">
+        <div class="panel-title">Risk vs Impact Quadrant</div>
+        <svg id="quadrant" width="100%" viewBox="0 0 420 300"></svg>
+        <div class="legend">
+          <div class="legend-item"><div class="legend-dot" style="background:#00ff88"></div>Q2: Low Risk / High Impact (ideal)</div>
+        </div>
+      </div>
+
+      <!-- GAUGE + HEATMAP side by side -->
+      <div class="panel">
+        <div class="panel-title">Signal-to-Noise Ratio</div>
+        <svg id="gauge" width="100%" viewBox="0 0 420 220"></svg>
+      </div>
+
+      <div class="panel">
+        <div class="panel-title">Risk Assessment Heatmap</div>
+        <svg id="heatmap" width="100%" viewBox="0 0 420 300"></svg>
+      </div>
+
+      <!-- SUMMARY METRICS -->
+      <div class="metrics-row">
+        <div class="metric-card">
+          <div class="metric-value" style="color:#00ccff">8.2<span style="font-size:13px;color:var(--muted)">/10</span></div>
+          <div class="metric-label">Avg Idea Value</div>
+        </div>
+        <div class="metric-card">
+          <div class="metric-value" style="color:#00ff88">1.8<span style="font-size:13px;color:var(--muted)">/10</span></div>
+          <div class="metric-label">Avg Risk Score</div>
+        </div>
+        <div class="metric-card">
+          <div class="metric-value" style="color:#ffcc44">85%</div>
+          <div class="metric-label">Signal-to-Noise Ratio</div>
+        </div>
+        <div class="metric-card">
+          <div class="metric-value" style="color:#00ff88">100%</div>
+          <div class="metric-label">Implementation Success</div>
+        </div>
+        <div class="metric-card">
+          <div class="metric-value" style="color:#00ccff">90%</div>
+          <div class="metric-label">Risk Mitigation</div>
+        </div>
+      </div>
+
+    </div>
+
+    <script>
+      // ── Helpers ──────────────────────────────────────────────────────────────
+      const ns = 'http://www.w3.org/2000/svg';
+      function el(tag, attrs = {}, children = []) {
+        const e = document.createElementNS(ns, tag);
+        for (const [k, v] of Object.entries(attrs)) e.setAttribute(k, v);
+        children.forEach(c => typeof c === 'string'
+          ? e.appendChild(document.createTextNode(c))
+          : e.appendChild(c));
+        return e;
+      }
+
+      // ── Scatter ──────────────────────────────────────────────────────────────
+      (function buildScatter() {
+        const svg = document.getElementById('scatter');
+        const W = 420, H = 300;
+        const pad = { top: 20, right: 20, bottom: 40, left: 40 };
+        const cw = W - pad.left - pad.right;
+        const ch = H - pad.top - pad.bottom;
+
+        const xDom = [0, 6], yDom = [0, 10];
+        const xScale = v => pad.left + (v - xDom[0]) / (xDom[1] - xDom[0]) * cw;
+        const yScale = v => pad.top + ch - (v - yDom[0]) / (yDom[1] - yDom[0]) * ch;
+
+        const ideas = [
+          { x: 1, y: 9, name: 'Workspace Config' },
+          { x: 2, y: 8, name: 'Tool Setup' },
+          { x: 3, y: 9, name: 'Search Interface' },
+          { x: 4, y: 7, name: 'Issue Investigation' },
+          { x: 5, y: 8, name: 'System Health Check' },
+        ];
+
+        // Risk threshold line
+        const thresholdY = yScale(5);
+        svg.appendChild(el('line', {
+          x1: xScale(0), y1: thresholdY,
+          x2: xScale(6), y2: thresholdY,
+          stroke: '#ff3366', 'stroke-width': '1',
+          'stroke-dasharray': '4 3', opacity: '0.7'
+        }));
+        svg.appendChild(el('text', {
+          x: xScale(5.9), y: thresholdY - 5,
+          fill: '#ff3366', 'font-size': '9',
+          'text-anchor': 'end', opacity: '0.7'
+        }, ['threshold']));
+
+        // Grid lines
+        for (let x = 1; x <= 5; x++) {
+          svg.appendChild(el('line', {
+            x1: xScale(x), y1: pad.top,
+            x2: xScale(x), y2: pad.top + ch,
+            stroke: 'rgba(255,255,255,0.04)', 'stroke-width': '1'
+          }));
+        }
+        for (let y = 0; y <= 10; y += 2) {
+          svg.appendChild(el('line', {
+            x1: pad.left, y1: yScale(y),
+            x2: pad.left + cw, y2: yScale(y),
+            stroke: 'rgba(255,255,255,0.04)', 'stroke-width': '1'
+          }));
+        }
+
+        // Axes
+        svg.appendChild(el('line', {
+          x1: pad.left, y1: pad.top,
+          x2: pad.left, y2: pad.top + ch,
+          stroke: 'rgba(255,255,255,0.2)', 'stroke-width': '1'
+        }));
+        svg.appendChild(el('line', {
+          x1: pad.left, y1: pad.top + ch,
+          x2: pad.left + cw, y2: pad.top + ch,
+          stroke: 'rgba(255,255,255,0.2)', 'stroke-width': '1'
+        }));
+
+        // Axis labels
+        svg.appendChild(el('text', {
+          x: pad.left + cw / 2, y: H - 4,
+          fill: 'rgba(224,224,240,0.45)', 'font-size': '10',
+          'text-anchor': 'middle'
+        }, ['Complexity of Implementation']));
+        const yLabel = el('text', {
+          x: 10, y: pad.top + ch / 2,
+          fill: 'rgba(224,224,240,0.45)', 'font-size': '10',
+          'text-anchor': 'middle',
+          transform: `rotate(-90, 10, ${pad.top + ch / 2})`
+        }, ['Expected Value / Reward']);
+        svg.appendChild(yLabel);
+
+        // X axis ticks
+        for (let x = 1; x <= 5; x++) {
+          svg.appendChild(el('text', {
+            x: xScale(x), y: pad.top + ch + 14,
+            fill: 'rgba(224,224,240,0.45)', 'font-size': '9',
+            'text-anchor': 'middle'
+          }, [String(x)]));
+        }
+        for (let y = 0; y <= 10; y += 2) {
+          svg.appendChild(el('text', {
+            x: pad.left - 6, y: yScale(y) + 3,
+            fill: 'rgba(224,224,240,0.45)', 'font-size': '9',
+            'text-anchor': 'end'
+          }, [String(y)]));
+        }
+
+        // Data points
+        ideas.forEach(d => {
+          const cx = xScale(d.x), cy = yScale(d.y);
+
+          // glow
+          svg.appendChild(el('circle', {
+            cx, cy, r: '10',
+            fill: '#00ccff', opacity: '0.08'
+          }));
+          // dot
+          svg.appendChild(el('circle', {
+            cx, cy, r: '5',
+            fill: '#00ccff', opacity: '0.9'
+          }));
+          // label
+          svg.appendChild(el('text', {
+            x: cx, y: cy - 10,
+            fill: '#e0e0f0', 'font-size': '9',
+            'text-anchor': 'middle', opacity: '0.8'
+          }, [d.name]));
+        });
+      })();
+
+      // ── Quadrant ─────────────────────────────────────────────────────────────
+      (function buildQuadrant() {
+        const svg = document.getElementById('quadrant');
+        const W = 420, H = 300;
+        const pad = { top: 20, right: 20, bottom: 40, left: 50 };
+        const cw = W - pad.left - pad.right;
+        const ch = H - pad.top - pad.bottom;
+
+        const mx = pad.left + cw / 2;
+        const my = pad.top + ch / 2;
+
+        const items = [
+          { name: 'Tool Dev',           x: 0.2, y: 0.8 },
+          { name: 'Workspace Config',   x: 0.1, y: 0.9 },
+          { name: 'Search Interface',   x: 0.3, y: 0.7 },
+          { name: 'Issue Investigation',x: 0.1, y: 0.6 },
+          { name: 'System Analysis',    x: 0.2, y: 0.8 },
+        ];
+
+        const xScale = v => pad.left + v * cw;
+        const yScale = v => pad.top + (1 - v) * ch;
+
+        // Quadrant fills
+        const quadrants = [
+          { x: mx, y: pad.top, w: cw / 2, h: ch / 2, color: 'rgba(255,100,100,0.06)', label: 'High Risk\nHigh Impact' },
+          { x: pad.left, y: pad.top, w: cw / 2, h: ch / 2, color: 'rgba(0,255,136,0.07)', label: 'Low Risk\nHigh Impact' },
+          { x: pad.left, y: my, w: cw / 2, h: ch / 2, color: 'rgba(200,200,200,0.04)', label: 'Low Risk\nLow Impact' },
+          { x: mx, y: my, w: cw / 2, h: ch / 2, color: 'rgba(255,100,100,0.04)', label: 'High Risk\nLow Impact' },
+        ];
+        quadrants.forEach((q, i) => {
+          svg.appendChild(el('rect', {
+            x: q.x, y: q.y, width: q.w, height: q.h,
+            fill: q.color, rx: '2'
+          }));
+          const labels = q.label.split('\n');
