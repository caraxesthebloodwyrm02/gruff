+import test from "node:test";
+import assert from "node:assert/strict";
+import { generateId, generateRunId, parseRunId, isRunId } from "../dist/id.js";
+
+test("generateId keeps legacy prefix-timestamp-hex shape", () => {
+  const id = generateId("run");
+  assert.match(id, /^run-\d+-[0-9a-f]{8}$/);
+});
+
+test("generateRunId emits {service}.{kind}.{uuid}", () => {
+  const id = generateRunId("ori", "run");
+  const parts = id.split(".");
+  assert.equal(parts.length, 3);
+  assert.equal(parts[0], "ori");
+  assert.equal(parts[1], "run");
+  assert.match(parts[2], /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/);
+});
+
+test("generateRunId rejects invalid segments", () => {
+  assert.throws(() => generateRunId("Ori", "run"));
+  assert.throws(() => generateRunId("ori", "Run"));
+  assert.throws(() => generateRunId("ori.sub", "run"));
+  assert.throws(() => generateRunId("", "run"));
+  assert.throws(() => generateRunId("ori", ""));
+  assert.throws(() => generateRunId("1ori", "run"));
+});
+
+test("parseRunId round-trips", () => {
+  const id = generateRunId("afloat-server", "exec");
+  const parsed = parseRunId(id);
+  assert.ok(parsed);
+  assert.equal(parsed.service, "afloat-server");
+  assert.equal(parsed.kind, "exec");
+  assert.equal(`${parsed.service}.${parsed.kind}.${parsed.uuid}`, id);
+});
+
+test("parseRunId rejects malformed ids", () => {
+  assert.equal(parseRunId("no-dots-here"), null);
+  assert.equal(parseRunId("only.two"), null);
+  assert.equal(parseRunId(".kind.uuid"), null);
+  assert.equal(parseRunId("svc..uuid"), null);
+  assert.equal(parseRunId("svc.kind."), null);
+  assert.equal(parseRunId("Svc.kind.uuid"), null);
+});
+
+test("isRunId distinguishes new from legacy ids", () => {
+  assert.equal(isRunId(generateRunId("ori", "run")), true);
+  assert.equal(isRunId(generateId("run")), false);
+});
