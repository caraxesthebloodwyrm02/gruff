+import assert from "node:assert/strict";
+import { mkdtempSync, readFileSync, rmSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { join } from "node:path";
+import test from "node:test";
+
+const tempRoot = mkdtempSync(join(tmpdir(), "command-bus-test-"));
+const auditPath = join(tempRoot, "audit.ndjson");
+process.env.ECHOES_AUDIT_PATH = auditPath;
+
+const { dispatch, subscribe } = await import("../dist/command-bus.js");
+const { emitAudit } = await import("../dist/audit-client.js");
+const { generateRunId } = await import("../dist/id.js");
+
+test.after(() => {
+  rmSync(tempRoot, { recursive: true, force: true });
+});
+
+test("dispatch writes a command envelope line", async () => {
+  const ok = await dispatch({
+    runId: generateRunId("eligibility-server", "case"),
+    ns: "eligibility",
+    source: "eligibility-server",
+    command: "case_opened",
+    payload: { caseId: "case-1" },
+  });
+
+  assert.equal(ok, true);
+  const text = readFileSync(auditPath, "utf8");
+  assert.match(text, /"command":"case_opened"/);
+  assert.match(text, /"ns":"eligibility"/);
+});
+
+test("dispatch rejects invalid runId", async () => {
+  await assert.rejects(() =>
+    dispatch({
+      runId: "bad-run-id",
+      ns: "eligibility",
+      source: "eligibility-server",
+      command: "case_opened",
+      payload: { caseId: "case-2" },
+    }),
+  );
+});
+
+test("subscribe receives only matching namespace commands", async () => {
+  const received = [];
+  const sub = subscribe("pulse", (envelope) => {
+    received.push(envelope.command);
+  });
+
+  await dispatch({
+    runId: generateRunId("pulse-server", "briefing"),
+    ns: "pulse",
+    source: "pulse-server",
+    command: "briefing_include",
+    payload: { id: "a" },
+  });
+
+  await dispatch({
+    runId: generateRunId("eligibility-server", "case"),
+    ns: "eligibility",
+    source: "eligibility-server",
+    command: "case_opened",
+    payload: { id: "b" },
+  });
+
+  await new Promise((resolve) => setTimeout(resolve, 150));
+  sub.unsubscribe();
+
+  assert.deepEqual(received, ["briefing_include"]);
+});
+
+test("subscribe skips audit events in same NDJSON file", async () => {
+  const received = [];
+  const sub = subscribe("grid", (envelope) => {
+    received.push(envelope.command);
+  });
+
+  await emitAudit({
+    source: "grid-server",
+    tool: "health",
+    status: "success",
+    metadata: { type: "audit_only" },
+  });
+
+  await dispatch({
+    runId: generateRunId("grid-server", "health"),
+    ns: "grid",
+    source: "grid-server",
+    command: "health_probe",
+    payload: { ok: true },
+  });
+
+  await new Promise((resolve) => setTimeout(resolve, 150));
+  sub.unsubscribe();
+
+  assert.deepEqual(received, ["health_probe"]);
+});
