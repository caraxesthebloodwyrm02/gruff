+        });
+
+        // "Safe zone" annotation
+        svg.appendChild(el('text', {
+          x: pad.left + 8, y: pad.top + ch - 6,
+          fill: 'rgba(0,255,136,0.5)', 'font-size': '9', 'font-style': 'italic'
+        }, ['safe zone']));
+        svg.appendChild(el('text', {
+          x: pad.left + cw - 8, y: pad.top + 14,
+          fill: 'rgba(255,80,80,0.5)', 'font-size': '9', 'font-style': 'italic',
+          'text-anchor': 'end'
+        }, ['danger zone']));
+      })();
+    </script>
+  </body>
+</html>
