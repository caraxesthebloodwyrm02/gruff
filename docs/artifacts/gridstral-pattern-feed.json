    "reserved_pct_note": "~8% wet: submodule drift, .env, review-package, per-host plane verification",
    "verify_command": "make fourfold-snap",
    "seal_path": "docs/artifacts/session-seal.json",
    "corners": [
      { "corner": "NW", "fold_id": 1, "path": "LICENSE" },
      { "corner": "NE", "fold_id": 2, "path": "DESIGN.md" },
      { "corner": "SE", "fold_id": 3, "path": "Makefile" },
      { "corner": "SW", "fold_id": 4, "path": "INSTRUCTION.md" }
    ]
  },
  "gain": {
    "dry_pct_target": 67,
    "wet_pct_target": 33,
    "ping_pong_stroke": ["dry_read_octant", "wet_act_edit", "dry_reconcile_link"],
    "triplet_shape": ["octant_id", "dry_anchor", "wet_note"],
    "dotted_rhythm": ["anchor", "gesture_voice", "swing_metric"]
  },
  "neighborhood_graph": {
    "nodes": ["LICENSE", "DESIGN.md", "Makefile", "INSTRUCTION.md", "REFERENCE.md"],
    "edges_undirected": [
      ["LICENSE", "REFERENCE.md"],
      ["LICENSE", "DESIGN.md"],
      ["DESIGN.md", "INSTRUCTION.md"],
      ["DESIGN.md", "Makefile"],
      ["INSTRUCTION.md", "Makefile"],
      ["REFERENCE.md", "DESIGN.md"],
      ["REFERENCE.md", "INSTRUCTION.md"],
      ["REFERENCE.md", "Makefile"]
    ]
  },
  "neighborhood_rules": [
    "within_stratum: move along archetype columns covenant↔cadence",
    "across_strata_same_archetype: 2→6→10→14 etc for same_question_deeper_repo",
    "folds_1_4: literal fourfold cluster at umbrella stratum",
    "commits_hogsmade: folds 5-8",
    "commits_grid: folds 9-12",
    "commits_umbrella_overlay: folds 13-16 except submodule pointer work uses folds 4 and 8"
  ],
  "swing_vs_gesture": {
    "swing_metrics": [
      "hops_from_REFERENCE_to_anchor",
      "submodules_touched_count",
      "octant_band O1-O4 vs O5-O8"
    ],
    "gesture_signals": [
      "prince: implement",
      "hermes: cross_repo_align",
      "caraxes: marketplace_scout",
      "grid: single_window_only",
      "overlay: gates_elevator_lap"
    ],
    "programmable_checks": [
      "if hops_gt 3 then suggest REFERENCE_row_or_fold_pointer",
      "if gesture_hermes but edits_only_grid then rescope_to_grid_octant",
      "name_octant_before_touching_code"
    ]
  },
  "voices": [
    {
      "id": "prince-runtime-intel",
      "default": true,
      "when": "default_implementation_Mangrove_Cascade"
    },
    {
      "id": "hermes",
      "default": false,
      "when": "submodule_pointer_CascadeProjects_cross_repo"
    },
    {
      "id": "caraxes",
      "default": false,
      "when": "marketplace_plugin_scout"
    },
    {
      "id": "grid-window",
      "default": false,
      "when": "GRID-main one of python frontend electron landing"
    },
    {
      "id": "pi-isolation",
      "default": false,
      "when": "CascadeProjects/.pi AGENTS network rules"
    }
