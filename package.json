{
  "name": "@irfankabir002/gruff",
  "version": "0.1.3",
  "description": "Workspace cockpit + trust-routing overlay — GRID design system tokens, voice guide, 4-quadrant TUI, and actor-scoring layer over the MCP fleet.",
  "type": "module",
  "main": "./dist/cli.js",
  "license": "Apache-2.0",
  "author": "Irfan Kabir <irfankabir02@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caraxesthebloodwyrm02/gruff.git"
  },
  "homepage": "https://github.com/caraxesthebloodwyrm02/gruff#readme",
  "bugs": {
    "url": "https://github.com/caraxesthebloodwyrm02/gruff/issues"
  },
  "keywords": [
    "cli",
    "tui",
    "ink",
    "mcp",
    "audit",
    "trust-routing",
    "design-system",
    "gruff"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "gruff": "dist/cli.js",
    "gruff-ingester": "dist/trust/ingester.js"
  },
  "exports": {
    "./tokens.json": "./design-system/tokens.json",
    "./schemas/gruff-proportion-v1": "./schemas/gruff-proportion-v1.schema.json",
    "./schemas/trust-event-v1": "./schemas/trust-event-v1.schema.json"
  },
  "files": [
    "dist",
    "design-system/README.md",
    "design-system/colors_and_type.css",
    "design-system/tokens.json",
    "design-system/assets/*.svg",
    "schemas/gruff-proportion-v1.schema.json",
    "schemas/trust-event-v1.schema.json",
    "templates/gruff.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && node scripts/extract-tokens.mjs",
    "dev": "tsx --watch src/cli.tsx",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test src/trust/scorer.test.ts src/trust/db.test.ts src/commands/proportion.test.ts",
    "prepublishOnly": "npm run build && npm run lint && npm test",
    "orchestrate": "bash ./scripts/orchestrate.sh"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^11.10.0",
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.14",
    "@types/react": "^18.3.21",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "~5.8.3"
  }
}
