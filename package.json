{
  "name": "@irfankabir002/gruff",
  "version": "1.0.0",
  "description": "Local Filesystem Umbrella - Trust infrastructure with real-time actor tracking",
  "main": "dist/cli.js",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx --watch src/cli.tsx",
    "lint": "tsc --noEmit",
