    "coverage": "c8 node --import tsx --test src/*.test.ts src/**/*.test.ts"
  },
  "bin": {
    "gruff": "dist/cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.0.0",
    "commander": "^14.0.3",
    "ink": "^4.0.0",
    "js-yaml": "^4.1.1",
    "tsup": "^8.5.0",
    "tsx": "^4.8.0",
    "typescript": "^5.0.0"
  },
  "types": "dist/cli.d.ts",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "c8": "^11.0.0"
  }
}
